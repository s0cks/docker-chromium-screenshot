---
const { meta } = Astro.props;
---
<main>
  <section class="card">
    <header>
      <h3>API Throttle Rate</h3>
    </header>

    <main>
      <data class="kpi" value="0.04">0.04%</data>
    </main>

    <footer>
      <output class="ind" aria-label="Decrease of 12.4%">
        <span class="trend positive">-12.4%</span>
        <small>vs trailing hour</small>
      </output>
    </footer>
  </section>

  <section class="card">
    <header>
      <h3>Active Users</h3>
    </header>

    <main>
      <data>12.4k</data>
    </main>

    <footer>
      <small>Daily active concurrent sessions.</small>
    </footer>
  </section>

  <section class="card card-1x2">
    <header>
      <h3>Load Time</h3>
    </header>

    <main>
      <data>0.8s</data>
    </main>

    <footer>
      <small>Average global response time.</small>
    </footer>
  </section>

  <section class="card">
    <header>
      <h3>Campaign Goals</h3>
    </header>

    <main>
      <small>75% of our annual milestone targets achieved ahead of schedule.</small>
    </main>
  </section>

  <section class="card">
    <header>
      <h3>Global Reach</h3>
    </header>

    <main>
      <small>Our infrastructure expanded across 14 new regional data hubs, securing lower latency for over 35 million newly acquired users across APAC and EMEA regions.</small>
    </main>
  </section>

  <section class="card">
    <header>
      <h3>Campaign Goals</h3>
    </header>

    <main>
      <small>75% of our annual milestone targets achieved ahead of schedule.</small>
    </main>
  </section>

  <section class="card active">
    <header>
      <h3>Campaign Goals</h3>
    </header>

    <main>
      <small>75% of our annual milestone targets achieved ahead of schedule.</small>
    </main>
  </section>

  <section class="card highlight">
    <header>
      <h3>Campaign Goals</h3>
    </header>

    <main>
      <small>75% of our annual milestone targets achieved ahead of schedule.</small>
    </main>
  </section>
</main>
